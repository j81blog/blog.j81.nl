{{- $pages := where site.RegularPages "Section" "in" (slice "posts" "howto") -}}
{{- $index := slice -}}
{{- range $pages -}}
  {{- $index = $index | append (dict
        "title" .Title
        "url" .RelPermalink
        "date" (.Date.Format "2006-01-02")
        "section" .Section
        "tags" (.Params.tags | default slice)
        "content" (substr .Plain 0 4000)
      ) -}}
{{- end -}}
{{- $index | jsonify -}}
